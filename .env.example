# ============================================================
# EDD Starter Kit — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----- LLM Provider (pick ONE, comment out the other) -----
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ----- Arize Phoenix Cloud -----
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_API_KEY=

# ----- Student Identity (used in trace metadata) -----
STUDENT_NAME=your-name-here
